{
  "expo": {
    "name": "DeepDiet",
    "slug": "deepdietmobile",
    "version": "1.0.0",
    "scheme": "deepdietmobile",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.begum.deepdietmobile",
      "infoPlist": {
        "NSCameraUsageDescription": "DeepDiet yemek analizleri için kameranıza ihtiyaç duyar.",
        "NSPhotoLibraryUsageDescription": "DeepDiet galerinizden yemek seçebilmeniz için izin ister."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
